# IntelliDocs Environment Variables
# Copy this file to .env and fill in values:
#   cp .env.example .env

# --- Database ---
DB_PASSWORD=change_me

# --- Redis ---
REDIS_PASSWORD=change_me

# --- RabbitMQ ---
RABBITMQ_PASSWORD=change_me

# --- LLM ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Google OAuth ---
# Google Cloud Console → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Deployment ---
# Public URL (used for NEXT_PUBLIC_API_URL during frontend build)
EXTERNAL_URL=http://localhost
# Domain for SSL certificate (used by init-ssl.sh)
DOMAIN=intellidocs.org
