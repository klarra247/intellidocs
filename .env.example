# IntelliDocs Environment Variables
# Copy this file to .env and fill in values:
#   cp .env.example .env

# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
# PostgreSQL 호스트 (Docker 내부에서는 서비스명 'postgres')
DB_HOST=localhost
# PostgreSQL 포트
DB_PORT=5432
# 데이터베이스 이름
DB_NAME=intellidocs
# 데이터베이스 사용자
DB_USERNAME=intellidocs
# 데이터베이스 비밀번호 (프로덕션에서 반드시 변경)
DB_PASSWORD=change_me

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
# Redis 호스트
REDIS_HOST=localhost
# Redis 포트
REDIS_PORT=6379
# Redis 비밀번호 (프로덕션에서 반드시 변경)
REDIS_PASSWORD=change_me

# ─────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────
# RabbitMQ 호스트
RABBITMQ_HOST=localhost
# RabbitMQ AMQP 포트
RABBITMQ_PORT=5672
# RabbitMQ 사용자
RABBITMQ_USERNAME=intellidocs
# RabbitMQ 비밀번호 (프로덕션에서 반드시 변경)
RABBITMQ_PASSWORD=change_me
# RabbitMQ 가상 호스트
RABBITMQ_VHOST=intellidocs

# ─────────────────────────────────────────
# Elasticsearch
# ─────────────────────────────────────────
# Elasticsearch 호스트
ES_HOST=localhost
# Elasticsearch HTTP 포트
ES_PORT=9200

# ─────────────────────────────────────────
# Qdrant (벡터 DB)
# ─────────────────────────────────────────
# Qdrant 호스트
QDRANT_HOST=localhost
# Qdrant gRPC 포트
QDRANT_GRPC_PORT=6334

# ─────────────────────────────────────────
# 파일 저장
# ─────────────────────────────────────────
# 업로드 파일 저장 디렉토리
UPLOAD_DIR=/tmp/intellidocs/uploads

# ─────────────────────────────────────────
# AI 모델 (LLM)
# ─────────────────────────────────────────
# LLM 프로바이더 (anthropic 또는 openai)
LLM_PROVIDER=anthropic
# Anthropic API 키 (LLM_PROVIDER=anthropic 일 때 필수)
ANTHROPIC_API_KEY=
# Anthropic 모델명
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OpenAI API 키 (LLM_PROVIDER=openai 일 때 필수)
OPENAI_API_KEY=
# OpenAI 채팅 모델명
OPENAI_MODEL=gpt-4.1-mini
# OpenAI 임베딩 모델명
EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────
# 인증 (JWT)
# ─────────────────────────────────────────
# JWT 서명 키 (프로덕션에서 반드시 256비트 이상 랜덤 키로 변경)
JWT_SECRET=dev-secret-key-change-in-production-min-256-bits-required-here
# JWT 액세스 토큰 만료 (ms) — 기본 24시간
JWT_EXPIRATION=86400000
# JWT 리프레시 토큰 만료 (ms) — 기본 7일
JWT_REFRESH_EXPIRATION_MS=604800000

# ─────────────────────────────────────────
# Google OAuth (ID Token 검증 방식 — Client Secret 불필요)
# ─────────────────────────────────────────
# Google Cloud Console → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=
# 프론트엔드용 Google Client ID (빌드 시 주입)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
# 허용할 Origin (쉼표 구분으로 복수 지정 가능)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# 배포
# ─────────────────────────────────────────
# 외부 접근 URL (프론트엔드 빌드 시 NEXT_PUBLIC_API_URL로 사용)
EXTERNAL_URL=http://localhost
# SSL 인증서용 도메인 (init-ssl.sh에서 사용)
DOMAIN=intellidocs.org

# ─────────────────────────────────────────
# Spring 프로파일
# ─────────────────────────────────────────
# 활성 프로파일 (local 또는 prod)
SPRING_PROFILES_ACTIVE=local

# ─────────────────────────────────────────
# 서버
# ─────────────────────────────────────────
# Spring Boot 서버 포트
SERVER_PORT=8080
# Python 파싱 서비스 URL
PARSING_SERVICE_URL=http://localhost:8000
